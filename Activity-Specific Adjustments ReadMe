Usage
from activity_adjustments import activity_specific_score
# inside the main fitness function:
def fitness(schedule):
    score = 0.0
    # ... per-activity scoring loop (room size, facilitator, conflicts) ...

    # add cross-activity adjustments
    score += activity_specific_score(schedule)
    return score

